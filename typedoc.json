{
	"$schema": "https://typedoc.org/schema.json",
	"entryPoints": [
		"./src/core/index.ts",
		"./src/features/file-handling/index.ts",
		"./src/features/visualization/index.ts",
		"./src/grasshopper.ts",
		"./src/index.ts"
	],
	"out": "docs/api",
	"name": "Selva Compute API Reference",
	"exclude": ["**/*.test.ts", "**/__tests__/**"],
	"includeVersion": true,
	"readme": "README.md",
	"plugin": ["typedoc-plugin-missing-exports", "typedoc-plugin-extras"],
	"hideGenerator": true,
	"customFooterHtml": "Powered by VektorNode"
}
