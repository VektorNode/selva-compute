{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"ignoreDeprecations": "6.0",
		"outDir": "dist",
		"baseUrl": ".",
		"paths": {
			"@/*": ["./src/*"],
			"@tests/*": ["./tests/*"]
		},
		"types": ["node", "vitest/globals"]
	},
	"include": ["src/**/*", "tests/**/*"],
	"exclude": ["node_modules", "dist"]
}
